+function bindPrepInteractions() {
+  // Persisted follow-up checkboxes — write through via toggleFollowUp
+  briefingModalBodyEl.querySelectorAll('[data-prep-persisted]').forEach((input) => {
+    input.addEventListener('change', () => {
+      const [meetingId, lineIndexStr] = String(input.getAttribute('data-prep-persisted') || '').split('::');
+      const lineIndex = Number(lineIndexStr);
+      if (!meetingId || !Number.isFinite(lineIndex)) return;
+      const reportId = app.activeBriefing?.report?.id;
+      if (!reportId) return;
+      toggleFollowUp(reportId, meetingId, lineIndex, !!input.checked);
+      // toggleFollowUp calls render(); rebuild briefing to reflect new follow-up state
+      rebuildActiveBriefing();
+    });
+  });
+  // Auto-prompt checkboxes — session-local
+  briefingModalBodyEl.querySelectorAll('[data-prep-auto]').forEach((input) => {
+    input.addEventListener('change', () => {
+      const key = input.getAttribute('data-prep-auto');
+      if (!key || !app.ui.prepSession) return;
+      app.ui.prepSession.tickedAutoKeys = app.ui.prepSession.tickedAutoKeys || {};
+      app.ui.prepSession.tickedAutoKeys[key] = !!input.checked;
+      // Toggle the visual class without a full re-render to keep focus and input state
+      const li = input.closest('.prep-item');
+      if (li) li.classList.toggle('done', !!input.checked);
+    });
+  });
+  // Custom agenda checkboxes
+  briefingModalBodyEl.querySelectorAll('[data-prep-custom]').forEach((input) => {
+    input.addEventListener('change', () => {
+      const id = input.getAttribute('data-prep-custom');
+      const session = app.ui.prepSession;
+      if (!id || !session) return;
+      const target = (session.customItems || []).find((item) => item.id === id);
+      if (target) target.done = !!input.checked;
+      const li = input.closest('.prep-item');
+      if (li) li.classList.toggle('done', !!input.checked);
+    });
+  });
+  // Custom agenda remove buttons
+  briefingModalBodyEl.querySelectorAll('[data-prep-custom-remove]').forEach((btn) => {
+    btn.addEventListener('click', () => {
+      const id = btn.getAttribute('data-prep-custom-remove');
+      const session = app.ui.prepSession;
+      if (!id || !session) return;
+      session.customItems = (session.customItems || []).filter((item) => item.id !== id);
+      renderActiveBriefingBody();
+    });
+  });
+  // Add-agenda input: Enter key or Add button
+  const addInput = document.getElementById('prepAgendaInput');
+  const addBtn = document.getElementById('prepAgendaAddBtn');
+  const commitAdd = () => {
+    if (!addInput || !app.ui.prepSession) return;
+    const text = normalizeText(addInput.value);
+    if (!text) return;
+    app.ui.prepSession.customItems = app.ui.prepSession.customItems || [];
+    app.ui.prepSession.customItems.push({ id: nextId('prep'), text, done: false });
+    addInput.value = '';
+    renderActiveBriefingBody();
+    // Re-focus the input so the user can keep adding items
+    document.getElementById('prepAgendaInput')?.focus();
+  };
+  addInput?.addEventListener('keydown', (event) => {
+    if (event.key === 'Enter') {
+      event.preventDefault();
+      commitAdd();
+    }
+  });
+  addBtn?.addEventListener('click', commitAdd);
+}
